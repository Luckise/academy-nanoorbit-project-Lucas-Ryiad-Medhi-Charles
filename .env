# Hôte de l'API NanoOrbit
#
# Cas 1 — Émulateur Android Studio sur la même machine :
#   API_BASE_URL=http://10.0.2.2:5000/
#
# Cas 2 — Émulateur docker-android (conteneur sur le même réseau Docker) :
#   API_BASE_URL=http://nanoorbit_api:5000/
#
# Cas 3 — Device physique sur le LAN :
#   API_BASE_URL=http://<ip_du_pc>:5000/
API_BASE_URL=http://nanoorbit_api:5000/
